---
import { business } from '../data/business';
---

<!-- Floating action buttons — desktop only -->
<div class="hidden lg:flex flex-col gap-3 fixed bottom-6 right-6 z-50">
  <!-- WhatsApp -->
  <a
    href={`https://wa.me/${business.phone.viber}`}
    class="flex w-14 h-14 bg-[#25D366] text-white rounded-full items-center justify-center shadow-lg hover:scale-110 transition-transform duration-200 whatsapp-pulse"
    data-event="chat_click"
    data-source="whatsapp_float"
    aria-label="Пишете ни в WhatsApp"
    title="Пишете ни в WhatsApp"
    target="_blank"
    rel="noopener noreferrer"
  >
    <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
    </svg>
  </a>

  <!-- Viber -->
  <a
    href={`viber://chat?number=${business.phone.viber}`}
    class="flex w-14 h-14 bg-viber text-white rounded-full items-center justify-center shadow-lg hover:scale-110 transition-transform duration-200 viber-pulse"
    data-event="chat_click"
    data-source="viber_float"
    aria-label="Пишете ни в Viber"
    title="Пишете ни в Viber"
  >
    <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M11.4 0C5.5.1.1 4.4 0 10.2c-.1 3.5 1.3 6.8 3.8 9.1L2.5 24l5-1.4c1.5.8 3.2 1.2 4.9 1.2 6.5 0 11.7-5.1 11.7-11.4S17.9 0 11.4 0zm0 21c-1.5 0-3-.4-4.3-1.1l-.3-.2-3 .8.9-2.8-.2-.3C2.3 16 1.2 13.1 1.3 10.2 1.4 5.1 5.9 1.2 11.4 1.1 17 1.1 21.5 5.5 21.5 11c0 5.5-4.5 10-10.1 10zm5.5-7.5c-.3-.1-1.7-.8-2-1-.3-.1-.5-.1-.7.1-.2.2-.7.9-.9 1.1-.2.2-.3.2-.6.1-.3-.1-1.2-.4-2.3-1.4-.9-.8-1.5-1.7-1.6-2-.2-.3 0-.5.1-.6.1-.1.3-.3.4-.5.1-.2.1-.3.2-.5 0-.2 0-.4-.1-.5-.1-.1-.7-1.7-.9-2.4-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.4s1 2.8 1.2 3c.2.2 2.1 3.2 5.1 4.4.7.3 1.3.5 1.7.6.7.2 1.4.2 1.9.1.6-.1 1.7-.7 2-1.4.2-.7.2-1.2.2-1.3 0-.2-.2-.3-.5-.4z"/>
    </svg>
  </a>
</div>

<style>
  @keyframes pulse-ring {
    0% { box-shadow: 0 0 0 0 rgba(current, 0.5); }
    70% { box-shadow: 0 0 0 12px rgba(current, 0); }
    100% { box-shadow: 0 0 0 0 rgba(current, 0); }
  }

  .whatsapp-pulse {
    animation: whatsapp-pulse-anim 2s infinite;
  }
  @keyframes whatsapp-pulse-anim {
    0% { box-shadow: 0 0 0 0 rgba(37, 211, 102, 0.6); }
    70% { box-shadow: 0 0 0 14px rgba(37, 211, 102, 0); }
    100% { box-shadow: 0 0 0 0 rgba(37, 211, 102, 0); }
  }

  .viber-pulse {
    animation: viber-pulse-anim 2s infinite;
    animation-delay: 1s;
  }
  @keyframes viber-pulse-anim {
    0% { box-shadow: 0 0 0 0 rgba(124, 77, 255, 0.6); }
    70% { box-shadow: 0 0 0 14px rgba(124, 77, 255, 0); }
    100% { box-shadow: 0 0 0 0 rgba(124, 77, 255, 0); }
  }
</style>
