---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import MobileCallBar from '../components/MobileCallBar.astro';
import ViberFloat from '../components/ViberFloat.astro';
import SchemaOrg from '../components/SchemaOrg.astro';
import { business } from '../data/business';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  noindex?: boolean;
  schema?: object | object[];
  breadcrumbs?: { name: string; url: string }[];
  preloadImage?: string;
}

const {
  title,
  description,
  canonical,
  ogImage = '/images/og-default-v2.webp',
  ogType = 'website',
  noindex = false,
  schema,
  breadcrumbs,
  preloadImage,
} = Astro.props;

const canonicalUrl = canonical ?? new URL(Astro.url.pathname, business.siteUrl).href;
const ogImageUrl = ogImage.startsWith('http') ? ogImage : `${business.siteUrl}${ogImage}`;

// Organization schema — global
const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: business.name,
  url: business.siteUrl,
  logo: `${business.siteUrl}/images/logo.png`,
  contactPoint: {
    '@type': 'ContactPoint',
    telephone: business.phone.tel,
    contactType: 'customer service',
    availableLanguage: 'Bulgarian',
    areaServed: 'BG',
  },
};

// WebSite schema with SearchAction
const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: business.name,
  url: business.siteUrl,
  potentialAction: {
    '@type': 'SearchAction',
    target: {
      '@type': 'EntryPoint',
      urlTemplate: `${business.siteUrl}/vaprosi-i-otgovori/?q={search_term_string}`,
    },
    'query-input': 'required name=search_term_string',
  },
};

// Breadcrumb schema
const breadcrumbSchema = breadcrumbs && breadcrumbs.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Начало', item: business.siteUrl },
    ...breadcrumbs.map((b, i) => ({
      '@type': 'ListItem',
      position: i + 2,
      name: b.name,
      item: `${business.siteUrl}${b.url}`,
    })),
  ],
} : null;

const allSchemas = [
  orgSchema,
  websiteSchema,
  ...(breadcrumbSchema ? [breadcrumbSchema] : []),
  ...(schema ? (Array.isArray(schema) ? schema : [schema]) : []),
];
---

<!doctype html>
<html lang="bg" dir="ltr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />

  <!-- Primary meta -->
  <title>{title}</title>
  <meta name="description" content={description} />
  {noindex && <meta name="robots" content="noindex, nofollow" />}
  <link rel="canonical" href={canonicalUrl} />

  <!-- Open Graph -->
  <meta property="og:type" content={ogType} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:site_name" content={business.name} />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:locale" content="bg_BG" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageUrl} />

  <!-- Favicon & PWA manifest -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" type="image/png" href="/favicon.png" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <link rel="manifest" href="/site.webmanifest" />
  <meta name="theme-color" content="#D4721A" />

  <!-- Font preconnect — using bunny.net (GDPR-safe) -->
  <link rel="preconnect" href="https://fonts.bunny.net" />
  <link rel="preconnect" href="https://fonts.bunny.net" crossorigin />
  <!-- Load font stylesheet non-render-blocking -->
  <link rel="preload" href="https://fonts.bunny.net/css?family=manrope:400,500,600,700,800&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'" />
  <noscript><link rel="stylesheet" href="https://fonts.bunny.net/css?family=manrope:400,500,600,700,800&display=swap" /></noscript>

  <!-- LCP image preload (page-specific) -->
  {preloadImage && <link rel="preload" as="image" href={preloadImage} fetchpriority="high" />}

  <!-- JS-gate: adds .js to <html> before first paint so CSS reveal-hidden states only apply when JS is confirmed -->
  <script>document.documentElement.classList.add('js')</script>

  <!-- Structured data -->
  <SchemaOrg schemas={allSchemas} />
</head>
<body class="min-h-screen flex flex-col">
  <!-- Skip to content for accessibility -->
  <a href="#main-content" class="skip-link">Към основното съдържание</a>

  <Header />

  <main id="main-content" class="flex-1">
    <slot />
  </main>

  <Footer />

  <!-- Fixed conversion elements -->
  <MobileCallBar />
  <ViberFloat />

  <!-- FAQ accordion and other page JS -->
  <script>
    // FAQ accordion — CSS max-height animation, icon rotates via aria-expanded
    (document.querySelectorAll('.faq-answer') as NodeListOf<HTMLElement>)
      .forEach(a => { a.style.display = ''; }); // remove server-rendered display:none

    document.querySelectorAll('.faq-question').forEach(btn => {
      btn.addEventListener('click', () => {
        const answerId = btn.getAttribute('aria-controls');
        const answer = (answerId
          ? document.getElementById(answerId)
          : btn.nextElementSibling) as HTMLElement | null;
        const isOpen = btn.getAttribute('aria-expanded') === 'true';

        // Close all
        document.querySelectorAll('.faq-answer').forEach(a => {
          (a as HTMLElement).classList.remove('faq-open');
        });
        document.querySelectorAll('.faq-question').forEach(b => {
          b.setAttribute('aria-expanded', 'false');
        });

        if (!isOpen && answer) {
          answer.classList.add('faq-open');
          btn.setAttribute('aria-expanded', 'true');
        }
      });
    });

    // Scroll reveal — IntersectionObserver adds .is-visible to .reveal-* elements
    const revealEls = document.querySelectorAll('.reveal, .reveal-up, .reveal-left, .reveal-right, .reveal-scale');
    if (revealEls.length > 0) {
      const revealObserver = new IntersectionObserver(
        (entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('is-visible');
              revealObserver.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.12, rootMargin: '0px 0px -48px 0px' }
      );
      revealEls.forEach(el => revealObserver.observe(el));
    }

    // Header scroll effect — adds .header-scrolled class after 60px scroll
    const siteHeader = document.querySelector('header');
    if (siteHeader) {
      const onScroll = () => {
        if (window.scrollY > 60) {
          siteHeader.classList.add('header-scrolled');
        } else {
          siteHeader.classList.remove('header-scrolled');
        }
      };
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();
    }

    // Analytics event tracking helper
    document.querySelectorAll('[data-event]').forEach(el => {
      el.addEventListener('click', () => {
        const event = el.getAttribute('data-event');
        const source = el.getAttribute('data-source') || 'unknown';
        const ctaName = el.getAttribute('data-cta-name') || '';
        // Hook for analytics — push to dataLayer when GTM is set up
        if (typeof window !== 'undefined' && (window as any).dataLayer) {
          (window as any).dataLayer.push({
            event: event,
            source: source,
            cta_name: ctaName,
          });
        }
      });
    });

    // ── Water ripple on scroll ────────────────────────────────
    (function() {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      let lastScroll = window.scrollY;
      let ticking = false;
      let rippleCooldown = false;

      function spawnRipple() {
        if (rippleCooldown) return;
        rippleCooldown = true;
        setTimeout(() => { rippleCooldown = false; }, 600);

        const el = document.createElement('div');
        el.className = 'water-ripple';
        const x = 15 + Math.random() * 70; // % from left
        const y = 15 + Math.random() * 70; // % from top, within viewport
        el.style.left = x + 'vw';
        el.style.top = ((y / 100) * window.innerHeight) + 'px';
        document.body.appendChild(el);
        setTimeout(() => el.remove(), 1500);
      }

      window.addEventListener('scroll', () => {
        if (!ticking) {
          requestAnimationFrame(() => {
            const delta = Math.abs(window.scrollY - lastScroll);
            if (delta > 80) {
              spawnRipple();
              lastScroll = window.scrollY;
            }
            ticking = false;
          });
          ticking = true;
        }
      }, { passive: true });
    })();

    // ── Cursor water drop trail (desktop only) ────────────────
    (function() {
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      if (window.matchMedia('(hover: none)').matches) return; // skip touch devices
      if (window.innerWidth < 1024) return;

      let lastX = 0, lastY = 0, dropCooldown = false;

      document.addEventListener('mousemove', (e) => {
        if (dropCooldown) return;
        const dx = e.clientX - lastX;
        const dy = e.clientY - lastY;
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < 28) return; // only spawn when mouse moves enough

        dropCooldown = true;
        setTimeout(() => { dropCooldown = false; }, 120);

        lastX = e.clientX;
        lastY = e.clientY;

        const drop = document.createElement('div');
        drop.className = 'cursor-drop';
        drop.style.left = e.clientX + 'px';
        drop.style.top = (e.clientY + window.scrollY) + 'px';
        // slight random horizontal drift
        const drift = (Math.random() - 0.5) * 10;
        drop.style.marginLeft = drift + 'px';
        document.body.appendChild(drop);
        setTimeout(() => drop.remove(), 900);
      });
    })();
  </script>
</body>
</html>
