﻿﻿---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CTABlock from '../../components/CTABlock.astro';
import { business, priceCategories } from '../../data/business';

const icons: Record<string, string> = {
  'Монтаж на санитария': `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9h18v10a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/><path d="M3 9a6 6 0 016-6h6a6 6 0 016 6"/></svg>`,
  'Смесители и кранове': `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>`,
  'Бойлери и водогрейни': `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="2" width="18" height="20" rx="2"/><path d="M12 7v5"/><circle cx="12" cy="15" r="2"/></svg>`,
  'Уреди': `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="18" rx="2"/><path d="M7 7h2M15 7h2M7 11h10"/></svg>`,
  'Сифони': `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a5 5 0 00-5 5v3H5a2 2 0 000 4h14a2 2 0 000-4h-2V7a5 5 0 00-5-5z"/><path d="M12 14v6M9 20h6"/></svg>`,
  'Канализация и отпушване': `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 16.3c2.2 0 4-1.83 4-4.05 0-1.16-.57-2.26-1.71-3.19S7.29 7.9 7 5.6c-.29 2.3-1.1 3.3-2.29 4.46C3.57 10 3 11.1 3 12.25c0 2.22 1.8 4.05 4 4.05z"/><path d="M12.56 6.6A10.97 10.97 0 0014 3.02c.5 2.5 2 4.9 4 6.5s3 3.5 3 5.5a6.98 6.98 0 01-11.91 4.97"/></svg>`,
  'Водомери': `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>`,
  'По договаряне': `<svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/><path d="M9 12h6M9 16h4"/></svg>`,
};
---

<BaseLayout
  title="Цени на ВиК услуги в София — ВиК Петров 2025"
  description="Пълна ценова листа на ВиК услуги в София. Монтаж на санитария, бойлери, смесители, отпушване. Ориентировъчни цени 2025. ВиК Петров — 0896 934 144."
  breadcrumbs={[{ name: 'Цени', url: '/ceni/' }]}
>
  <Breadcrumb items={[{ name: 'Цени' }]} />

  <!-- HERO BANNER -->
  <section class="section bg-primary" style="padding-block: 3.5rem;">
    <div class="container">
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 text-sm font-semibold mb-4 bg-white/10 px-3 py-1.5 rounded-full border border-white/20" style="color:rgba(255,255,255,0.80)">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
          Актуални цени 2025
        </div>
        <h1 class="text-4xl md:text-5xl font-bold mb-4" style="color:#ffffff;">Цени на ВиК услуги</h1>
        <p class="text-lg md:text-xl mb-6" style="color:rgba(255,255,255,0.88);">
          Прозрачни цени за труд — без скрити такси, без такса за повикване.
          Точна оферта получавате <strong style="color:#ffffff;">безплатно на място</strong>.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href={`tel:${business.phone.tel}`} class="cta-call-dark" data-event="call_click" data-source="ceni_hero">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z"/></svg>
            {business.phone.display}
          </a>
          <a href="/kontakti/#form" class="cta-outline-dark" data-event="cta_click" data-source="ceni_hero">
            Заявете оглед
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- TRUST BAR -->
  <section class="section-stats-strip py-5">
    <div class="container">
      <div class="flex flex-wrap gap-x-8 gap-y-3 items-center justify-center text-sm font-semibold text-text-secondary">
        {[
          'Само труд — без скрити такси',
          'Без такса за повикване',
          'Плащане след работата',
        ].map(t => (
          <span class="flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            {t}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- IMPORTANT NOTICE -->
  <section class="section bg-white" style="padding-block: 2rem 0;">
    <div class="container">
      <div class="flex items-start gap-3 bg-bg-blue border border-blue-200 rounded-xl p-5 max-w-3xl">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 mt-0.5 text-primary" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
        <p class="text-sm text-text-secondary">
          <strong class="text-text">Важно:</strong> Цените са ориентировъчни и могат да варират според конкретния обект, материалите и сложността.

        </p>
      </div>
    </div>
  </section>

  <!-- PRICE CATEGORIES GRID -->
  <section class="section bg-white">
    <div class="container">
      <div class="grid gap-5">
        {priceCategories.map((cat, catIdx) => (
          <div
            class={`reveal-up rounded-2xl overflow-hidden border shadow-card ${cat.negotiable ? 'border-gray-200' : 'border-blue-100'}`}
            style={`transition-delay: ${catIdx * 50}ms`}
          >
            <div class={`flex items-center gap-3 px-6 py-4 ${cat.negotiable ? 'bg-gray-50' : 'bg-bg-blue'}`}>
              <span class={cat.negotiable ? 'text-text-muted' : 'text-primary'} set:html={icons[cat.name] ?? icons['Водомери']} />
              <h2 class={`font-bold text-lg ${cat.negotiable ? 'text-text-secondary' : 'text-primary'}`}>{cat.name}</h2>
              {cat.negotiable && (
                <span class="ml-auto text-xs font-semibold text-text-muted bg-gray-200 px-2.5 py-0.5 rounded-full">По договаряне</span>
              )}
            </div>
            <div class="bg-white">
              {cat.items.map((item, idx) => (
                <div class={`flex items-center justify-between gap-6 px-6 py-3 text-sm ${idx % 2 === 0 ? 'bg-white' : 'bg-gray-50/70'} ${idx < cat.items.length - 1 ? 'border-b border-gray-100' : ''}`}>
                  <span class="text-text-secondary">{item.service}</span>
                  <span class={`shrink-0 font-bold ${cat.negotiable ? 'text-text-muted italic text-xs' : 'text-primary'}`}>{item.price}</span>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- WHAT'S INCLUDED -->
  <section class="section bg-bg-light">
    <div class="container">
      <div class="max-w-4xl mx-auto">
        <h2 class="reveal-up text-2xl font-bold text-text mb-8 text-center">Как формираме цените?</h2>
        <div class="grid md:grid-cols-2 gap-6 mb-6">
          <div class="reveal-up card">
            <div class="flex items-center gap-3 mb-5">
              <span class="w-9 h-9 rounded-full flex items-center justify-center shrink-0" style="background:rgba(16,185,129,0.12)">
                <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="color:#10B981" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
              </span>
              <h3 class="font-bold text-text">Включено в цената</h3>
            </div>
            <ul class="space-y-3">
              {[
                'Труд на квалифициран водопроводчик',
                'Дребни консумативи (тефлон, уплътнения)',
                'Проверка за течове след монтажа',
                'Транспорт в рамките на София',
              ].map(item => (
                <li class="flex items-start gap-2.5 text-sm text-text-secondary">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 mt-0.5" style="color:#10B981" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>
          <div class="reveal-up card" style="transition-delay:80ms">
            <div class="flex items-center gap-3 mb-5">
              <span class="w-9 h-9 rounded-full flex items-center justify-center shrink-0" style="background:rgba(230,57,70,0.10)">
                <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="color:#E63946" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
              </span>
              <h3 class="font-bold text-text">Не е включено в цената</h3>
            </div>
            <ul class="space-y-3">
              {[
                'Санитария (вана, мивка, тоалетна) — осигурява се от клиента',
                'Смесители и кранове',
                'Тръби и фитинги (при реконструкция)',
              ].map(item => (
                <li class="flex items-start gap-2.5 text-sm text-text-secondary">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 mt-0.5" style="color:#E63946" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                  {item}
                </li>
              ))}
            </ul>
          </div>
        </div>
        <div class="reveal-up bg-white rounded-xl border border-blue-100 p-5 flex items-center gap-4">
          <span class="w-10 h-10 rounded-full flex items-center justify-center shrink-0" style="background:rgba(11,95,255,0.08)">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-primary" aria-hidden="true"><rect x="1" y="4" width="22" height="16" rx="2"/><path d="M1 10h22"/></svg>
          </span>
          <div>
            <p class="font-semibold text-text text-sm">Плащане след извършване на работата</p>
            <p class="text-text-muted text-sm mt-0.5">При по-голям проект може да се уговори авансово плащане. Приемаме плащане в брой.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CTABlock
    title="Искате точна оферта?"
    subtitle="Обадете се и насрочете удобно за вас."
    source="ceni_page_cta"
  />
</BaseLayout>