---

import BaseLayout from '../layouts/BaseLayout.astro';

import TrustStrip from '../components/TrustStrip.astro';

import CTABlock from '../components/CTABlock.astro';

import ServiceCard from '../components/ServiceCard.astro';

import TestimonialCard from '../components/TestimonialCard.astro';

import ContactForm from '../components/ContactForm.astro';

import { business, services, priceCategories } from '../data/business';



// LocalBusiness + Plumber schema

const localBusinessSchema = {

  '@context': 'https://schema.org',

  '@type': ['LocalBusiness', 'Plumber'],

  name: business.name,

  image: `${business.siteUrl}/images/og-default-v2.webp`,

  '@id': `${business.siteUrl}/#business`,

  url: business.siteUrl,

  telephone: business.phone.tel,

  email: business.email,

  priceRange: '$$',

  address: {

    '@type': 'PostalAddress',

    streetAddress: business.address.street,

    addressLocality: business.address.city,

    postalCode: business.address.postalCode,

    addressCountry: business.address.country,

    addressRegion: business.address.region,

  },

  geo: {

    '@type': 'GeoCoordinates',

    latitude: business.coordinates.lat,

    longitude: business.coordinates.lng,

  },

  openingHoursSpecification: business.hours.schema.map(h => {

    const [day, hours] = h.split(' ');

    const [opens, closes] = hours.split('-');

    const dayMap: Record<string, string> = {

      Mo: 'Monday', Tu: 'Tuesday', We: 'Wednesday', Th: 'Thursday',

      Fr: 'Friday', Sa: 'Saturday', Su: 'Sunday',

    };

    return {

      '@type': 'OpeningHoursSpecification',

      dayOfWeek: `https://schema.org/${dayMap[day]}`,

      opens,

      closes,

    };

  }),

  areaServed: [

    'София', 'Панчарево', 'Кокаляне', 'Лозен', 'Герман', 'Горубляне',

    'Бистрица', 'Бояна', 'Драгалевци', 'Симеоново', 'Младост', 'Дружба',

    'Кривина', 'Казичене', 'Пасарел',

  ],

  aggregateRating: {

    '@type': 'AggregateRating',

    ratingValue: '4.9',

    reviewCount: '87',

    bestRating: '5',

  },

  founder: {

    '@type': 'Person',

    name: business.owner,

  },

};



const testimonials = [

  {

    name: 'Мария К.',

    neighborhood: 'Бояна',

    rating: 5,

    text: 'Теодор дойде за по-малко от час при теч от тръба. Смени всичко, почисти след себе си. Много доволна от работата!',

    date: '2025-03-15',

  },

  {

    name: 'Георги С.',

    neighborhood: 'Младост',

    rating: 5,

    text: 'Монтира ни нова душ кабина и мивка. Прецизна работа, уважителен отзив и разумна цена. Препоръчвам!',

    date: '2025-02-20',

  },

  {

    name: 'Анна Д.',

    neighborhood: 'Драгалевци',

    rating: 5,

    text: 'Спешен случай — запушена тоалетна. Теодор отговори веднага и реши проблема за 45 минути. Пет звезди!',

    date: '2025-04-01',

  },

  {

    name: 'Петър В.',

    neighborhood: 'Симеоново',

    rating: 5,

    text: 'Смяна на бойлер и монтаж на смесители. Качествена работа, дава 12-месечна гаранция. Ще го препоръчам на всички.',

    date: '2025-01-10',

  },

];



const howWeWorkSteps = [

  { num: 1, title: 'Обаждате се', desc: 'Обаждате се или пишете в Viber. Отговаряме в рамките на минути.' },

  { num: 2, title: 'Идваме на оглед', desc: 'Пристигаме до 1 час.' },

  { num: 3, title: 'Получавате оферта', desc: 'Даваме ясна цена без скрити такси — предварително.' },

  { num: 4, title: 'Извършваме работата', desc: 'Работим бързо и чисто. Гаранция 12 месеца.' },

];

---



<BaseLayout

  title="ВиК услуги в София — Водопроводчик Теодор Петров"

  description="ВиК Петров — водопроводчик в София. При вас до 1 час. 12 години опит, 4000+ обекта, гаранция 12 месеца. Без скрити такси. Обадете се: 0896 934 144."

  schema={localBusinessSchema}

  preloadImage="/images/hero-bg.webp"

>



  <!-- HERO -->

  <section class="relative overflow-hidden hero-section" style="background-color: #3a2a1a; background-image: url(/images/hero-bg.webp); background-size: cover; background-position: center center;">

    <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">

      <div class="absolute -right-32 -top-32 w-96 h-96 rounded-full" style="background: rgba(255,255,255,0.04);"></div>

      <div class="absolute right-16 top-16 w-48 h-48 rounded-full" style="background: rgba(255,255,255,0.05);"></div>

      <div class="absolute -left-16 bottom-0 w-80 h-80 rounded-full" style="background: rgba(255,255,255,0.03);"></div>

      <div class="hero-overlay absolute inset-0"></div>


    </div>



    <div class="container relative py-16 md:py-24 lg:py-28">

      <div class="grid lg:grid-cols-2 gap-12 items-center">

        <div>

          <div class="hero-badge inline-flex items-center gap-2 bg-white/20 text-white text-sm font-bold px-4 py-2 rounded-full mb-6 border border-white/20" style="text-shadow: 0 1px 6px rgba(0,0,0,0.45);">

            <span class="w-2 h-2 bg-success rounded-full animate-pulse-slow"></span>

            Свободен сега — обадете се

          </div>



          <h1 class="hero-title text-4xl md:text-5xl lg:text-5xl font-bold leading-tight mb-4" style="color: #ffffff; text-shadow: 0 2px 12px rgba(0,0,0,0.55), 0 1px 3px rgba(0,0,0,0.40);">

            Водопроводчик<br />

            <span style="color: #D4721A;">в София</span> —<br />

            при вас до 1 час

          </h1>



          <p class="hero-subtitle text-lg md:text-xl mb-8 max-w-lg" style="color:#ffffff; text-shadow: 0 1px 8px rgba(0,0,0,0.50);">

            Теодор Петров — {business.experience} години опит, {business.stats.clients} доволни клиенти, гаранция {business.warranty}.

            Казваме цената <strong style="color:#fff; text-shadow: inherit;">преди да започнем</strong>. Без скрити такси.

          </p>



          <div class="hero-ctas flex flex-col sm:flex-row gap-4 mb-8">

            <a

              href={`tel:${business.phone.tel}`}

              class="cta-call-dark"

              data-event="call_click"

              data-source="hero"

              data-cta-name="hero_call"

            >

              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">

                <path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z"/><path d="M15 5a4 4 0 014 4"/><path d="M15 2a7 7 0 017 7"/>

              </svg>

              {business.phone.display}

            </a>

            <a

              href={`viber://chat?number=${business.phone.viber}`}

              class="cta-outline-dark"

              data-event="viber_click"

              data-source="hero"

              data-cta-name="hero_viber"

            >

              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M11.4 0C5.5.1.1 4.4 0 10.2c-.1 3.5 1.3 6.8 3.8 9.1L2.5 24l5-1.4c1.5.8 3.2 1.2 4.9 1.2 6.5 0 11.7-5.1 11.7-11.4S17.9 0 11.4 0zm0 21c-1.5 0-3-.4-4.3-1.1l-.3-.2-3 .8.9-2.8-.2-.3C2.3 16 1.2 13.1 1.3 10.2 1.4 5.1 5.9 1.2 11.4 1.1 17 1.1 21.5 5.5 21.5 11c0 5.5-4.5 10-10.1 10zm5.5-7.5c-.3-.1-1.7-.8-2-1-.3-.1-.5-.1-.7.1-.2.2-.7.9-.9 1.1-.2.2-.3.2-.6.1-.3-.1-1.2-.4-2.3-1.4-.9-.8-1.5-1.7-1.6-2-.2-.3 0-.5.1-.6.1-.1.3-.3.4-.5.1-.2.1-.3.2-.5 0-.2 0-.4-.1-.5-.1-.1-.7-1.7-.9-2.4-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.5.1-.8.4-.3.3-1 1-1 2.4s1 2.8 1.2 3c.2.2 2.1 3.2 5.1 4.4.7.3 1.3.5 1.7.6.7.2 1.4.2 1.9.1.6-.1 1.7-.7 2-1.4.2-.7.2-1.2.2-1.3 0-.2-.2-.3-.5-.4z"/>
              </svg>

              Пишете в Viber

            </a>

          </div>



          <div class="hero-trust">



            <TrustStrip dark={true} />



          </div>

        </div>



        <div class="hero-form lg:max-w-md lg:ml-auto w-full">

          <ContactForm dark={true} />

        </div>

      </div>

    </div>

  </section>



  <!-- STATS STRIP -->

  <section class="section-stats-strip py-8">

    <div class="container">

      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">

        <div>

          <div class="text-3xl font-bold text-primary">{business.experience}+</div>

          <div class="text-text-secondary text-sm mt-1">години опит</div>

        </div>

        <div>

          <div class="text-3xl font-bold text-primary">{business.stats.clients}</div>

          <div class="text-text-secondary text-sm mt-1">доволни клиенти</div>

        </div>

        <div>

          <div class="text-3xl font-bold text-primary">1 ч.</div>

          <div class="text-text-secondary text-sm mt-1">реакция при авария</div>

        </div>

        <div>

          <div class="text-3xl font-bold text-primary">12 мес.</div>

          <div class="text-text-secondary text-sm mt-1">гаранция</div>

        </div>

      </div>

    </div>

  </section>



  <!-- SERVICES GRID -->

  <section class="section bg-bg-light" aria-labelledby="services-heading">

    <div class="container">

      <div class="reveal-up text-center mb-12">

        <h2 id="services-heading" class="reveal-up text-3xl font-bold text-text mb-4">Нашите услуги</h2>

        <p class="text-text-secondary text-lg max-w-2xl mx-auto">

          Извършваме всички видове ВиК ремонти и монтажи в Sofia — от смяна на смесител до цялостно обзавеждане на баня.

        </p>

      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">

        {[...services].sort((a, b) => (b.isEmergency ? 1 : 0) - (a.isEmergency ? 1 : 0)).map(s => (

          <ServiceCard

            slug={s.slug}

            title={s.shortTitle}

            description={s.summary.split('.')[0] + '.'}

            priceLabel={s.priceLabel}

            icon={s.icon}

            isEmergency={s.isEmergency}

          />

        ))}

      </div>

      <div class="text-center mt-10">

        <a href="/uslugi/" class="btn-secondary text-lg px-8 py-3" data-event="cta_click" data-source="homepage_services" data-cta-name="all_services">

          Всички услуги →

        </a>

      </div>

    </div>

  </section>



  <!-- ABOUT / TRUST -->

  <section class="section bg-white" aria-labelledby="about-heading">

    <div class="container">

      <div class="grid lg:grid-cols-2 gap-12 items-center">

        <!-- Photo placeholder -->

        <div class="relative">

          <div class="aspect-[4/3] bg-bg-blue rounded-xl overflow-hidden flex items-center justify-center">

            <img

              src="/images/teodor-petrov-vodovodchik.webp"

              alt="Теодор Петров — водопроводчик ВиК Петров, монтаж на ВиК инсталации в София"

              width="600"

              height="450"

              loading="lazy"

              class="w-full h-full object-cover"

            />

          </div>

          <div class="absolute -bottom-4 -right-4 bg-white rounded-xl shadow-card p-4 text-center">

            <div class="text-2xl font-bold text-primary">{business.experience}+</div>

            <div class="text-xs text-text-secondary">години опит</div>

          </div>

        </div>



        <div>

          <h2 id="about-heading" class="reveal-up text-3xl font-bold text-text mb-4">

            Защо клиентите ни се доверяват?

          </h2>

          <p class="text-text-secondary text-lg mb-6">

            <strong class="text-text">ВиК Петров</strong> е специализирана фирма за ВиК услуги в София, основана от {business.owner}, с {business.experience} години опит. Работим директно — без посредници и скрити такси.

          </p>



          <ul class="space-y-4 mb-8">
            <li class="flex gap-3 items-start">
              <span class="shrink-0 mt-0.5 text-primary">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
                </svg>
              </span>
              <div>
                <strong class="text-text font-semibold">До {business.responseTime} при авария</strong>
                <p class="text-text-secondary text-sm">В над 80% от случаите пристигаме в рамките на 1 час.</p>
              </div>
            </li>
            <li class="flex gap-3 items-start">
              <span class="shrink-0 mt-0.5 text-primary">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                  <path d="M9 12l2 2 4-4"/>
                </svg>
              </span>
              <div>
                <strong class="text-text font-semibold">Гаранция {business.warranty}</strong>
                <p class="text-text-secondary text-sm">Всяка извършена услуга е с писмена гаранция.</p>
              </div>
            </li>
            <li class="flex gap-3 items-start">
              <span class="shrink-0 mt-0.5 text-primary">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <line x1="12" y1="1" x2="12" y2="23"/>
                  <path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/>
                </svg>
              </span>
              <div>
                <strong class="text-text font-semibold">Прозрачни цени</strong>
                <p class="text-text-secondary text-sm">Казваме цената преди да започнем работа. Без изненади.</p>
              </div>
            </li>
          </ul>



          <a href="/za-nas/" class="btn-secondary" data-event="cta_click" data-source="homepage_about" data-cta-name="about_page">

            Научете повече за нас

          </a>

        </div>

      </div>

    </div>

  </section>


<div class="wave-divider" aria-hidden="true">
  <svg viewBox="0 0 1440 56" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M0,28 C240,56 480,0 720,28 C960,0 1200,56 1440,28 L1440,56 L0,56 Z" fill="#122850"/>
  </svg>
</div>

  <!-- HOW WE WORK -->

  <section class="section bg-bg-blue" aria-labelledby="process-heading">

    <div class="container">

      <div class="reveal-up text-center mb-12">

        <h2 id="process-heading" class="reveal-up text-3xl font-bold text-text mb-4">Как работим</h2>

        <p class="text-text-secondary">Простите стъпки от обаждането до свършената работа.</p>

      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">

        {howWeWorkSteps.map(step => (
          <div class="stagger-item reveal-up text-center">

            <div class="w-12 h-12 rounded-full bg-primary text-white font-bold flex items-center justify-center text-xl mx-auto mb-4">

              {step.num}

            </div>

            <h3 class="text-lg font-bold text-text mb-2">{step.title}</h3>

            <p class="text-text-secondary text-sm">{step.desc}</p>

          </div>

        ))}

      </div>

    </div>

  </section>


<div class="wave-divider" aria-hidden="true">
  <svg viewBox="0 0 1440 56" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M0,28 C240,0 480,56 720,28 C960,56 1200,0 1440,28 L1440,56 L0,56 Z" fill="#0F2040"/>
  </svg>
</div>

  <!-- GALLERY -->

  <section class="section bg-white" aria-labelledby="gallery-heading">

    <div class="container">

      <div class="text-center mb-10">
        <h2 id="gallery-heading" class="reveal-up text-3xl font-bold text-text mb-4">Реални обекти</h2>
        <p class="text-text-secondary">Снимки от изпълнени ВиК проекти в София и региона.</p>
      </div>

      <!-- Category tabs -->
      <div class="flex justify-center gap-3 mb-8" id="gallery-tabs" role="tablist" aria-label="Категории галерия">
        <button
          role="tab"
          aria-selected="true"
          aria-controls="gallery-panel-pipes"
          id="gallery-tab-pipes"
          class="gallery-tab gallery-tab--active px-5 py-2.5 rounded-full text-sm font-semibold transition-all duration-200"
          data-panel="gallery-panel-pipes"
        >
          Прокарване на тръби
        </button>
        <button
          role="tab"
          aria-selected="false"
          aria-controls="gallery-panel-montaji"
          id="gallery-tab-montaji"
          class="gallery-tab px-5 py-2.5 rounded-full text-sm font-semibold transition-all duration-200"
          data-panel="gallery-panel-montaji"
        >
          Монтажи
        </button>
      </div>

      <!-- Gallery grid (rendered by JS with pagination) -->
      <div id="gallery-grid" class="grid grid-cols-2 md:grid-cols-3 gap-4 min-h-[200px]"></div>

      <!-- Pagination -->
      <div id="gallery-pagination" class="flex justify-center items-center gap-3 mt-8"></div>

    </div>

  </section>

  <!-- Lightbox overlay -->
  <div id="gallery-lightbox" style="display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,0.92);align-items:center;justify-content:center;" aria-modal="true" role="dialog" aria-label="Преглед на снимка">
    <button id="lb-close" style="position:absolute;top:1rem;right:1rem;background:rgba(255,255,255,0.15);border:none;border-radius:50%;width:2.75rem;height:2.75rem;cursor:pointer;display:flex;align-items:center;justify-content:center;color:#fff;font-size:1.5rem;" aria-label="Затвори">✕</button>
    <button id="lb-prev" style="position:absolute;left:1rem;top:50%;transform:translateY(-50%);background:rgba(255,255,255,0.15);border:none;border-radius:50%;width:2.75rem;height:2.75rem;cursor:pointer;display:flex;align-items:center;justify-content:center;color:#fff;font-size:1.4rem;" aria-label="Предишна снимка">←</button>
    <img id="lb-img" src="" alt="" style="max-width:90vw;max-height:88vh;object-fit:contain;border-radius:0.5rem;display:block;" />
    <button id="lb-next" style="position:absolute;right:1rem;top:50%;transform:translateY(-50%);background:rgba(255,255,255,0.15);border:none;border-radius:50%;width:2.75rem;height:2.75rem;cursor:pointer;display:flex;align-items:center;justify-content:center;color:#fff;font-size:1.4rem;" aria-label="Следваща снимка">→</button>
  </div>

  <style>
    .gallery-tab {
      background: rgba(15, 32, 64, 0.80);
      color: #7A9AB5;
      border: 1.5px solid rgba(212, 114, 26, 0.20);
    }
    .gallery-tab:hover {
      background: rgba(212, 114, 26, 0.10);
      color: #E8894A;
      border-color: rgba(212, 114, 26, 0.40);
    }
    .gallery-tab--active {
      background: #D4721A;
      color: #ffffff;
      border-color: #D4721A;
    }
    .gallery-page-btn {
      padding: 0.5rem 1.25rem;
      border-radius: 9999px;
      font-size: 0.875rem;
      font-weight: 600;
      border: 2px solid rgba(212, 114, 26, 0.45);
      color: #D4721A;
      background: rgba(15, 32, 64, 0.80);
      cursor: pointer;
      transition: all 0.2s;
    }
    .gallery-page-btn:hover {
      background: #D4721A;
      color: #fff;
      border-color: #D4721A;
    }
    .gallery-page-btn--active {
      background: #D4721A;
      color: #fff;
      border-color: #D4721A;
    }
    .gallery-page-btn:disabled {
      opacity: 0.35;
      cursor: default;
    }
    .gallery-thumb {
      cursor: zoom-in;
    }
  </style>

  <script>
    const GALLERY_IMAGES: Record<string, Array<{src: string; alt: string}>> = {
      pipes: [
        { src: '/images/viber_image_2026-05-03_22-33-44-694.webp', alt: 'Монтаж на канализационни тръби в сутерен' },
        { src: '/images/viber_image_2026-05-03_22-33-44-771.webp', alt: 'Разпределителен колектор с изолация в сутерен' },
        { src: '/images/viber_image_2026-05-03_22-33-45-000.webp', alt: 'Подмяна на стари ВиК тръби при ремонт' },
        { src: '/images/viber_image_2026-05-03_22-33-45-191.webp', alt: 'Демонтаж и преправка на баня' },
        { src: '/images/viber_image_2026-05-03_22-33-45-284.webp', alt: 'Нова ВиК инсталация в ново строителство' },
        { src: '/images/viber_image_2026-05-03_22-33-45-455.webp', alt: 'Полагане на тръби в ново строителство' },
        { src: '/images/gallery-new-1.webp', alt: 'ВиК ремонт' },
