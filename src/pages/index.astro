    const PER_PAGE_DESKTOP = 9;
    const PER_PAGE_MOBILE = 4;
    let activeCategory = 'pipes';
    let activePage = 1;

    function getPerPage(): number {
      return window.innerWidth < 768 ? PER_PAGE_MOBILE : PER_PAGE_DESKTOP;
    }

    const grid = document.getElementById('gallery-grid') as HTMLElement;
    const paginationEl = document.getElementById('gallery-pagination') as HTMLElement;

    // Lightbox
    let lbImages: Array<{src: string; alt: string}> = [];
    let lbIndex = 0;
    const lightbox = document.getElementById('gallery-lightbox') as HTMLElement;
    const lbImg = document.getElementById('lb-img') as HTMLImageElement;
    const lbClose = document.getElementById('lb-close') as HTMLButtonElement;
    const lbPrev = document.getElementById('lb-prev') as HTMLButtonElement;
    const lbNext = document.getElementById('lb-next') as HTMLButtonElement;

    function openLightbox(images: Array<{src: string; alt: string}>, index: number) {
      lbImages = images;
      lbIndex = index;
      lbImg.src = lbImages[lbIndex].src;
      lbImg.alt = lbImages[lbIndex].alt;
      lightbox.style.display = 'flex';
      document.body.style.overflow = 'hidden';
    }

    function closeLightbox() {
      lightbox.style.display = 'none';
      document.body.style.overflow = '';
    }

    function lbNavigate(dir: number) {
      lbIndex = (lbIndex + dir + lbImages.length) % lbImages.length;
      lbImg.src = lbImages[lbIndex].src;
      lbImg.alt = lbImages[lbIndex].alt;
    }

    lbClose.addEventListener('click', closeLightbox);
    lbPrev.addEventListener('click', () => lbNavigate(-1));
    lbNext.addEventListener('click', () => lbNavigate(1));
    lightbox.addEventListener('click', (e) => { if (e.target === lightbox) closeLightbox(); });
    document.addEventListener('keydown', (e) => {
      if (lightbox.style.display !== 'flex') return;
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowLeft') lbNavigate(-1);
      if (e.key === 'ArrowRight') lbNavigate(1);
    });

    function makeBtn(label: string, page: number, isActive: boolean, disabled: boolean): HTMLButtonElement {
      const btn = document.createElement('button');
      btn.className = 'gallery-page-btn' + (isActive ? ' gallery-page-btn--active' : '');
      btn.textContent = label;
      btn.disabled = disabled;
      if (!disabled) {
        btn.addEventListener('click', () => {
          activePage = page;
          renderGallery();
          grid.scrollIntoView({ behavior: 'smooth', block: 'start' });
        });
      }
      return btn;
    }

    function renderGallery() {
      const perPage = getPerPage();
      const images = GALLERY_IMAGES[activeCategory];
      const totalPages = Math.ceil(images.length / perPage);
      const slice = images.slice((activePage - 1) * perPage, activePage * perPage);

      while (grid.firstChild) grid.removeChild(grid.firstChild);
      slice.forEach((item, sliceIdx) => {
        const globalIdx = (activePage - 1) * perPage + sliceIdx;
        const wrap = document.createElement('div');
        wrap.className = 'gallery-thumb rounded-xl overflow-hidden aspect-[4/3]';
        const img = document.createElement('img');
        img.src = item.src;
        img.alt = item.alt;
        img.width = 600;
        img.height = 450;
        img.loading = 'lazy';
        img.className = 'w-full h-full object-cover hover:scale-105 transition-transform duration-500';
        wrap.appendChild(img);
        wrap.addEventListener('click', () => openLightbox(images, globalIdx));
        grid.appendChild(wrap);
      });

      while (paginationEl.firstChild) paginationEl.removeChild(paginationEl.firstChild);
      if (totalPages <= 1) return;

      paginationEl.appendChild(makeBtn('← Предишна', activePage - 1, false, activePage === 1));
      for (let p = 1; p <= totalPages; p++) {
        paginationEl.appendChild(makeBtn(String(p), p, p === activePage, false));
      }
      paginationEl.appendChild(makeBtn('Следваща →', activePage + 1, false, activePage === totalPages));
    }

    document.querySelectorAll<HTMLButtonElement>('#gallery-tabs .gallery-tab').forEach(tab => {
      tab.addEventListener('click', () => {
        document.querySelectorAll('#gallery-tabs .gallery-tab').forEach(t => {
          t.classList.remove('gallery-tab--active');
          t.setAttribute('aria-selected', 'false');
        });
        tab.classList.add('gallery-tab--active');
        tab.setAttribute('aria-selected', 'true');
        activeCategory = tab.dataset.panel === 'gallery-panel-montaji' ? 'montaji' : 'pipes';
        activePage = 1;
        renderGallery();
      });
    });

    renderGallery();
  </script>



