---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import CTABlock from '../../components/CTABlock.astro';
import { business, neighborhoods } from '../../data/business';
---

<BaseLayout
  title="Райони на обслужване — ВиК Петров София"
  description="ВиК Петров обслужва всички квартали на София и прилежащите села. Панчарево, Бояна, Младост, Драгалевци и още 10 района. Бърза реакция до 1 час."
  breadcrumbs={[{ name: 'Райони', url: '/rayoni/' }]}
>
  <Breadcrumb items={[{ name: 'Райони на обслужване' }]} />

  <section class="section bg-white">
    <div class="container">
      <div class="max-w-3xl mb-12">
        <h1 class="text-4xl font-bold text-text mb-4">Райони на обслужване</h1>
        <p class="text-xl text-text-secondary">
          {business.name} извършва ВиК услуги в цяла {business.address.city} и прилежащите квартали и села.
          Идваме до <strong>{business.responseTime}</strong>.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        {neighborhoods.map(n => (
          <a
            href={`/rayoni/${n.slug}/`}
            class="card group hover:border-primary border border-transparent transition-all"
          >
            <div class="w-10 h-10 bg-bg-blue rounded-xl flex items-center justify-center mb-4 group-hover:bg-primary transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#0B5FFF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:stroke-white" aria-hidden="true">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
            </div>
            <h2 class="text-lg font-bold text-text group-hover:text-primary transition-colors mb-2">
              {n.name}
            </h2>
            <p class="text-text-secondary text-sm line-clamp-2">
              {n.description}
            </p>
            <div class="mt-4 text-primary text-sm font-semibold group-hover:underline">
              ВиК услуги в {n.name} →
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CTABlock
    title="Не виждате вашия район?"
    subtitle="Обадете се — вероятно обслужваме и вашата зона. Работим в цяла Sofia и около нея."
    source="rayoni_index_cta"
  />
</BaseLayout>
