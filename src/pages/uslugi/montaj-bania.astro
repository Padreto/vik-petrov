  { service: 'Монтаж на вана', price: '125–155 EUR' },
  { service: 'Монтаж на душ-кабина', price: '125–160 EUR' },
  { service: 'Монтаж на тоалетна чиния за вградено казанче', price: '50–75 EUR' },
  { service: 'Монтаж на мивка с ботуш', price: '60–85 EUR' },
];

const whatIncluded = [
  'Изграждане или реконструкция на ВиК инсталация в банята',
  'Монтаж на вана, душ-кабина или душ-корито',
  'Монтаж на мивка и шкаф-мивка',
  'Монтаж на тоалетна чиния и казанче (стоящо или вградено)',
  'Монтаж на смесители за баня и вана',
  'Монтаж на сифони, гъвкави връзки и уплътнения',
  'Проверка за течове и изпитване на налягане',
  'Почистване след монтажа',
];

const whenNeeded = [
  { problem: 'Ремонт на баня', solution: 'При пълен ремонт на баня е нужна нова ВиК инсталация. Монтираме всичко от нулата или частично в зависимост от проекта.' },
  { problem: 'Стара, неизправна инсталация', solution: 'Остарелите тръби и фитинги текат и причиняват щети. Подменяме ги с модерни, надеждни материали.' },
  { problem: 'Нова баня в ново жилище', solution: 'При нов строеж или при обединяване на апартаменти изграждаме изцяло нова ВиК инсталация.' },
  { problem: 'Смяна на санитарията', solution: 'Ако искате нова вана, душ или тоалетна, ще монтираме всичко правилно и ще подменим необходимото от инсталацията.' },
];

const faq = [
  {
    q: 'Колко струва цялостен монтаж на баня в София?',
    a: 'Цялостният монтаж на ВиК инсталация в баня в София започва от 220 лв. и нагоре в зависимост от размера и сложността. Цената включва труд — материалите са отделно.',
  },
  {
    q: 'Извършвате ли и кърти-мажи дейности?',
    a: 'Не извършваме строително-ремонтни дейности (кърти-мажи). Занимаваме се само с ВиК — монтаж и свързване на санитария и тръбопроводи.',
  },
  {
    q: 'Колко дни отнема монтажът на баня?',
    a: 'Зависи от обема на работа. Само ВиК монтажът на стандартна баня отнема 1–3 работни дни след като строителната работа е завършена.',
  },
  {
    q: 'Дали е по-изгодно да поръчам всичко от един майстор?',
    a: 'Да, когато ВиК и санитарията се монтират от един специалист, е по-лесно за координация и отговорността е ясна. Всеки проблем е наша отговорност.',
  },
  {
    q: 'Дава ли се гаранция?',
    a: 'Да — 12 месеца гаранция за целия монтаж. При проблем в гаранционния период идваме и го отстраняваме безплатно.',
  },
];
---

<ServiceLayout
  title="Монтаж на баня в София — цени 2025 | ВиК Петров"
  h1="Цялостен монтаж на баня в София — цени 2025"
  description="Цялостен монтаж на баня в София от ВиК Петров. ВиК инсталация, вани, душ-кабини, мивки, тоалетни. Гаранция 12 месеца. Тел: 0896 934 144."
  slug="montaj-bania"
  summary="ВиК Петров изгражда цялостни ВиК инсталации за бани в София. Монтираме всички видове санитария — вани, душ-кабини, мивки, тоалетни, смесители. Даваме гаранция 12 месеца."
  priceLabel="от 135 EUR"
  priceItems={priceItems}
  whatIncluded={whatIncluded}
  whenNeeded={whenNeeded}
  faq={faq}
  relatedSlugs={['montaj-vana-dush', 'montaj-toaletna', 'montaj-mivka']}
/>
