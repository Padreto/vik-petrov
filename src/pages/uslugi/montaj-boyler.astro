---
import ServiceLayout from '../../layouts/ServiceLayout.astro';

const priceItems = [
  { service: 'Монтаж на бойлер', price: '50–80 EUR' },
  { service: 'Монтаж на проточен бойлер', price: '45–60 EUR' },
];

const whatIncluded = [
  'Демонтаж на стар бойлер (при наличие)',
  'Монтаж на новия бойлер на стената или на пода',
  'Свързване към студена вода, топла вода и канализация',
  'Монтаж на предпазен клапан и манометър',
  'Свързване към електрическата инсталация (220V)',
  'Проверка за течове и изпитване на налягане',
  'Инструктаж за правилна употреба',
];

const whenNeeded = [
  { problem: 'Бойлерът не загрява вода', solution: 'Причините могат да са различни — изгорял нагревател, повреден термостат или скала. Ще диагностицираме и ремонтираме или сменим бойлера.' },
  { problem: 'Стар бойлер при ремонт на баня', solution: 'При обновяване на банята е добър момент да смените и остарелия бойлер с по-ефективен модел.' },
  { problem: 'Теч от бойлера', solution: 'Теч от бойлера означава повреда на корпуса или клапаните. Бърза реакция е важна, за да избегнете наводнение.' },
  { problem: 'Преместване на бойлера', solution: 'При реновация понякога трябва да преместите бойлера на друго място. Занимаваме се с пренасочване на тръбопроводите.' },
  { problem: 'Монтаж на нов бойлер', solution: 'Ако нямате бойлер или искате да монтирате нов, ще ви помогнем с избора и монтажа.' },
];

const faq = [
  {
    q: 'Колко струва монтаж на бойлер в София?',
    a: 'Монтажът на бойлер в София струва между 80 и 130 лв. за натрупан бойлер, и 70–100 лв. за проточен. Цената зависи от вида и местоположението. Предоставяме точна оферта след оглед — безплатно.',
  },
  {
    q: 'Колко отнема монтажът на бойлер?',
    a: 'Стандартният монтаж на бойлер отнема между 1 и 3 часа, в зависимост от наличния достъп и старата инсталация.',
  },
  {
    q: 'Трябва ли ми нов бойлер или може да се ремонтира?',
    a: 'Много зависи от вида и възрастта на повредата. При проверка ще ви кажем честно дали си струва ремонтът или е по-изгодна подмяна.',
  },
  {
    q: 'Монтирате ли всички марки бойлери?',
    a: 'Да, монтираме бойлери на всички марки — Tesy, Gorenje, Mora, Ariston, Bosch, Atlantic и др.',
  },
  {
    q: 'Дава ли се гаранция за монтажа?',
    a: 'Да, даваме 12-месечна гаранция за извършения монтаж. Гаранцията за бойлера е съгласно условията на производителя.',
  },
  {
    q: 'Трябва ли да спирам водата за монтаж на бойлер?',
    a: 'Да, за монтажа трябва да спрем студената вода. Ще ви информираме предварително. Обикновено спирането е за не повече от 30–60 минути.',
  },
];
---

<ServiceLayout
  title="Монтаж на бойлер в София — цени и услуги | ВиК Петров"
  h1="Монтаж на бойлер в София — цени и услуги"
  description="Монтаж на бойлер в София от ВиК Петров. Натрупани и проточни бойлери. Цена 70–130 лв. Гаранция 12 месеца. Обадете се: 0896 934 144."
  slug="montaj-boyler"
  summary="ВиК Петров извършва монтаж на бойлер в София с 8 години опит. Монтираме натрупани и проточни бойлери на всички марки. Работим всеки ден, включително почивни дни."
  priceLabel="50–80 EUR"
  priceItems={priceItems}
  whatIncluded={whatIncluded}
  whenNeeded={whenNeeded}
  faq={faq}
  relatedSlugs={['montaj-smesitel', 'montaj-vana-dush', 'avariyni-vik-uslugi']}
/>
