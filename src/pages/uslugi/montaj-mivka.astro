---
import ServiceLayout from '../../layouts/ServiceLayout.astro';

const priceItems = [
  { service: 'Монтаж на мивка с ботуш', price: '100–140 лв.' },
  { service: 'Монтаж на шкаф–мивка за баня', price: '120–160 лв.' },
  { service: 'Монтаж на кухненска мивка', price: '120–160 лв.' },
  { service: 'Демонтаж и монтаж на мивка в баня', price: '100–140 лв.' },
  { service: 'Ремонт и монтаж на сифон за мивка', price: '60–80 лв.' },
];

const whatIncluded = [
  'Демонтаж на стара мивка (при замяна)',
  'Монтаж на новата мивка (конзолна, на ботуш или в плот)',
  'Свързване към водопровода (студена и топла вода)',
  'Монтаж на сифон и свързване към канализацията',
  'Монтаж на смесителя (при заявка)',
  'Проверка за течове',
  'Почистване след монтажа',
];

const whenNeeded = [
  { problem: 'Стара или спукана мивка', solution: 'Напукана или ръждясала мивка трябва да се смени. Ще монтираме новата без повреди.' },
  { problem: 'Монтаж на нова мивка при ремонт', solution: 'При ремонт на баня или кухня монтираме новата мивка правилно и прецизно.' },
  { problem: 'Теч под мивката', solution: 'Течовете под мивката обикновено са от сифона или гъвкавите връзки. Бърза и евтина поправка.' },
  { problem: 'Монтаж на шкаф-мивка', solution: 'Шкаф-мивките изискват правилен монтаж и нивелиране. Ще монтираме и ще свържем към водопровода.' },
];

const faq = [
  {
    q: 'Колко струва монтаж на мивка в София?',
    a: 'Монтажът на мивка в баня или кухня в София струва 100–160 лв. Цената зависи от вида мивка и монтажния начин.',
  },
  {
    q: 'Колко отнема монтажът?',
    a: 'Монтажът на мивка отнема 1–2 часа, включително свързване и тестване за течове.',
  },
  {
    q: 'Трябва ли ми ново сифонче?',
    a: 'При монтаж на нова мивка е препоръчително да се монтира и нов сифон. Ще проверим старото и ще ви кажем дали е за смяна.',
  },
  {
    q: 'Монтирате ли и кухненски мивки с мелачки?',
    a: 'Да, монтираме и сифони-мелачки за кухненски мивки. Цена 100–150 лв.',
  },
];
---

<ServiceLayout
  title="Монтаж на мивка в София — цени и услуги | ВиК Петров"
  h1="Монтаж на мивка в София — цени и услуги"
  description="Монтаж на мивка за баня и кухня в София от ВиК Петров. Цена 100–160 лв. Бърза реакция, гаранция 12 месеца. Тел: 0896 934 144."
  slug="montaj-mivka"
  summary="ВиК Петров монтира кухненски и банни мивки в София. Монтираме мивки с ботуш, шкаф-мивки и кухненски мивки. Монтажът включва сифон, гъвкави връзки и уплътнения."
  priceLabel="100–160 лв."
  priceItems={priceItems}
  whatIncluded={whatIncluded}
  whenNeeded={whenNeeded}
  faq={faq}
  relatedSlugs={['montaj-smesitel', 'montaj-bania', 'otpushvane-kanal']}
/>
