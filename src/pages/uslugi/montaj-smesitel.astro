---
import ServiceLayout from '../../layouts/ServiceLayout.astro';

const priceItems = [
  { service: 'Демонтаж и монтаж на смесител в баня (стоящ и стенен)', price: '80–130 лв.' },
  { service: 'Демонтаж и монтаж на смесител в кухня (стоящ и стенен)', price: '80–100 лв.' },
  { service: 'Ремонт и подмяна на смесител за вана', price: '100–120 лв.' },
  { service: 'Монтаж и ремонт на вграден смесител', price: '100–160 лв.' },
  { service: 'Ремонт, демонтаж и монтаж на кран преди водомер', price: '80–110 лв.' },
];

const whatIncluded = [
  'Демонтаж на стария смесител',
  'Почистване на резбите и фитингите',
  'Монтаж на новия смесител с тефлон и уплътнения',
  'Свързване на гъвкавите връзки (горещо и студено)',
  'Проверка за течове при всички точки',
  'Настройка на потока и температурата (при термостатни)',
];

const whenNeeded = [
  { problem: 'Смесителят капе', solution: 'Капещ смесител хаби вода и вдига сметките. Обикновено причината е изхабена гарнитура или O-ринг. Ще ремонтираме или сменим смесителя.' },
  { problem: 'Слаб напор на водата', solution: 'Запушена аерационна решетка или повредена вътрешна патрона. Ще почистим или сменим частите.' },
  { problem: 'Смесителят е стар и ръждясал', solution: 'Старите смесители са по-малко хигиенни и по-неефективни. Смяната им е инвестиция в комфорт.' },
  { problem: 'Монтаж на нов смесител', solution: 'Закупихте нов смесител? Ще го монтираме правилно, с правилните уплътнения и без риск от течове.' },
  { problem: 'Ремонт на баня', solution: 'При ремонт на баня или кухня е добър момент да смените и смесителите с по-нови модели.' },
];

const faq = [
  {
    q: 'Колко струва монтаж на смесител в София?',
    a: 'Монтажът на смесител в баня или кухня в София струва между 80 и 130 лв. Цената зависи от вида смесител и наличния достъп. Дадаваме точна оферта след оглед.',
  },
  {
    q: 'Трябва ли да спирате водата за смяна на смесители?',
    a: 'Да, за монтаж на смесител е нужно да спрем водата — или кранчетата под мивката, или главния кран. Процедурата е бърза — обикновено не повече от 15–30 минути.',
  },
  {
    q: 'Могата ли да си монтирам смесителя сам?',
    a: 'Технически е възможно, но рискувате течове при неправилно уплътнение или затягане. Течовете могат да причинят щети на съседите. По-безопасно е да се обадите на специалист.',
  },
  {
    q: 'Колко отнема монтажът на смесител?',
    a: 'Обикновено около 30–60 минути, включително тестване за течове.',
  },
  {
    q: 'Монтирате ли вградени (термостатни) смесители?',
    a: 'Да, монтираме и вградени смесители. Те изискват по-внимателна работа и малко повече время.',
  },
];
---

<ServiceLayout
  title="Монтаж на смесител в София — цени и услуги | ВиК Петров"
  h1="Монтаж на смесител в София — цени и услуги"
  description="Монтаж и подмяна на смесител в баня и кухня в София от ВиК Петров. Цена 80–130 лв. Гаранция 12 месеца. Тел: 0896 934 144."
  slug="montaj-smesitel"
  summary="ВиК Петров монтира и подменя смесители за баня и кухня в София. Работим с всички видове смесители — стоящи, стенни и вградени. Монтажът обикновено приключва за под 1 час."
  priceLabel="80–160 лв."
  priceItems={priceItems}
  whatIncluded={whatIncluded}
  whenNeeded={whenNeeded}
  faq={faq}
  relatedSlugs={['montaj-mivka', 'montaj-vana-dush', 'montaj-boyler']}
/>
