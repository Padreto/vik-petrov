---
import ServiceLayout from '../../layouts/ServiceLayout.astro';

const priceItems = [
  { service: 'Монтаж на тоалетна чиния за вградено казанче', price: '80–120 лв.' },
  { service: 'Монтаж на вградена конзола за казанче и тоалетна чиния', price: '180–250 лв.' },
  { service: 'Монтаж на структура за вградено казанче', price: '200–280 лв.' },
  { service: 'Ремонт на вградено казанче', price: '90–150 лв.' },
];

const whatIncluded = [
  'Демонтаж на старата тоалетна (при замяна)',
  'Монтаж на тоалетната чиния към канализационния отвор',
  'Свързване към водопроводната мрежа',
  'Монтаж на казанчето (стоящо) или конзолата (вградено)',
  'Регулиране на поплавъка и флапера',
  'Проверка за течове и правилен режим на изпускане',
  'Почистване след монтажа',
];

const whenNeeded = [
  { problem: 'Тоалетната тече или не изхвърля правилно', solution: 'Неправилно работещо казанче или повреден флапер — ремонтираме без да сменяме цялата тоалетна, ако е възможно.' },
  { problem: 'Стара или повредена тоалетна', solution: 'Напукана или остаряла тоалетна трябва да се смени. Ще монтираме новата бързо и прецизно.' },
  { problem: 'Монтаж на конзолна тоалетна', solution: 'Конзолните (висящи) тоалетни изискват монтаж на специална структура в стената. Занимаваме се с целия процес.' },
  { problem: 'Ремонт на вградено казанче', solution: 'Вградените казанчета понякога теклат или не работят правилно. Ще разглобим, ще проверим и ще сменим неизправните части.' },
];

const faq = [
  {
    q: 'Колко струва монтаж на тоалетна в София?',
    a: 'Монтажът на тоалетна чиния с наземно казанче струва 80–120 лв. За вградена конзолна тоалетна — 180–280 лв. Точната цена зависи от модела и достъпа.',
  },
  {
    q: 'Колко отнема монтажът на тоалетна?',
    a: 'Стандартна тоалетна с наземно казанче — около 1–2 часа. Конзолна тоалетна с вградена структура — 3–5 часа в зависимост от строителната готовност.',
  },
  {
    q: 'Тоалетната ми тече — трябва ли смяна?',
    a: 'Не задължително. Много течове се дължат на износен флапер или неправилно регулиран поплавък — части на стойност 10–20 лв. Ще проверим и ще ви кажем честно.',
  },
  {
    q: 'Нужен ли е строителен специалист за монтаж на конзолна тоалетна?',
    a: 'За монтажа на структурата в стената в идеалния случай трябва да е вече готова нишата или е нужно да се наеме строителен работник. ВиК Петров монтира само ВиК и структурата.',
  },
  {
    q: 'Дава ли се гаранция за монтажа?',
    a: 'Да — 12 месеца гаранция за всяка услуга.',
  },
];
---

<ServiceLayout
  title="Монтаж на тоалетна чиния в София — цени 2025 | ВиК Петров"
  h1="Монтаж на тоалетна чиния в София — цени 2025"
  description="Монтаж на тоалетна чиния, вградено казанче и конзолна тоалетна в София. ВиК Петров — от 80 лв. Гаранция 12 месеца. Тел: 0896 934 144."
  slug="montaj-toaletna"
  summary="ВиК Петров монтира тоалетни чинии, вградени казанчета и конзоли в София. Работим с всички известни марки. Даваме гаранция 12 месеца за извършения монтаж."
  priceLabel="80–280 лв."
  priceItems={priceItems}
  whatIncluded={whatIncluded}
  whenNeeded={whenNeeded}
  faq={faq}
  relatedSlugs={['montaj-bania', 'otpushvane-kanal', 'montaj-mivka']}
/>
