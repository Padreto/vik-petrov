---
import ServiceLayout from '../../layouts/ServiceLayout.astro';

const priceItems = [
  { service: 'Монтаж на вана', price: '125–155 EUR' },
  { service: 'Монтаж на душ-кабина', price: '125–160 EUR' },
  { service: 'Монтаж на душ-корито', price: '75–100 EUR' },
  { service: 'Ремонт и монтаж на сифон за вана', price: '60–85 EUR' },
];

const whatIncluded = [
  'Демонтаж на старата вана или душ-кабина (при замяна)',
  'Монтаж на новата вана или душ-корито на правилна хоризонтала',
  'Свързване към водопровода (студена и топла вода)',
  'Монтаж и свързване на сифона към канализацията',
  'Монтаж на смесителя (при заявка)',
  'Уплътняване и силиконизиране',
  'Проверка за течове',
  'Монтаж на душ-кабина (стени, врата, уплътнения)',
];

const whenNeeded = [
  { problem: 'Стара, повредена вана', solution: 'Изхабена или счупена вана трябва да се смени. Ще демонтираме старата и ще монтираме новата внимателно.' },
  { problem: 'Преминаване от вана към душ-кабина', solution: 'Популярна промяна при ремонт — демонтираме ваната и монтираме душ-корито и кабина.' },
  { problem: 'Теч от сифона на ваната', solution: 'Теч под ваната обикновено е от сифона или свръзките. Ремонтираме без да демонтираме ваната ако е достъпно.' },
  { problem: 'Монтаж на нова вана при ремонт', solution: 'При ремонт на баня монтираме нова вана с правилни мерки и правилно уплътнение.' },
];

const faq = [
  {
    q: 'Колко струва монтаж на вана в София?',
    a: 'Монтажът на вана в София струва 200–250 лв. Цената включва монтаж, сифон и свързване към водопровода и канализацията. Смесителят е отделно.',
  },
  {
    q: 'Трябва ли да купя и сифона за ваната?',
    a: 'Стандартен сифон за вана можете да осигурите сами или ние можем да го набавим. Ще уточним при огледа.',
  },
  {
    q: 'Монтирате ли вани и душ-кабини на всички марки?',
    a: 'Да, монтираме продукти на всички марки — VIDIMA, Ideal Standard, Roca, Grohe, Hansgrohe и др.',
  },
  {
    q: 'Колко дни отнема монтажът?',
    a: 'Монтажът на вана или душ-кабина обикновено отнема 1 ден. При по-сложни ситуации (пренасочване на тръби) може да е нужен и втори ден.',
  },
  {
    q: 'Силиконизирате ли след монтажа?',
    a: 'Да, уплътняваме ваната и душ-коритото към стените с качествен санитарен силикон.',
  },
];
---

<ServiceLayout
  title="Монтаж на вана и душ-кабина в София — цени 2025 | ВиК Петров"
  h1="Монтаж на вана и душ-кабина в София — цени 2025"
  description="Монтаж на вана, душ-кабина и душ-корито в София от ВиК Петров. Цена 120–260 лв. Гаранция 12 месеца. Тел: 0896 934 144."
  slug="montaj-vana-dush"
  summary="ВиК Петров монтира вани, душ-кабини и душ-корита в София с 8 години опит. Работим внимателно за да не повредим новата санитария. Включваме сифони и уплътнения в монтажа."
  priceLabel="75–160 EUR"
  priceItems={priceItems}
  whatIncluded={whatIncluded}
  whenNeeded={whenNeeded}
  faq={faq}
  relatedSlugs={['montaj-bania', 'montaj-smesitel', 'montaj-toaletna']}
/>
