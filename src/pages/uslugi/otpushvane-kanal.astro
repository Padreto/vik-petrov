---
import ServiceLayout from '../../layouts/ServiceLayout.astro';

const priceItems = [
  { service: 'Отпушване на тоалетна чиния', price: '70–120 лв.' },
  { service: 'Отпушване на канал в баня и кухня', price: '70–120 лв.' },
  { service: 'Монтаж на възвратна клапа ф110 – ф160', price: '150–250 лв.' },
];

const whatIncluded = [
  'Диагностика на запушването с проверка по канала',
  'Механично отпушване с тел или канален „змей"',
  'Хидравлично промиване при по-тежки запушвания',
  'Проверка за правилния отток след отпушването',
  'Съвети за предотвратяване на бъдещи запушвания',
  'Почистване на работната зона',
];

const whenNeeded = [
  { problem: 'Тоалетната не изхвърля вода', solution: 'Запушена тоалетна е честа авария. Решаваме проблема с механично отпушване без да разглобяваме цялата инсталация.' },
  { problem: 'Мивката или душ-коритото се пълни бавно', solution: 'Акумулирана мазнина, коса или детергент блокира оттока. Промиваме канала и изчистваме блокажа.' },
  { problem: 'Неприятна миризма от канализацията', solution: 'Неприятните миризми обикновено идват от изсъхнал сифон или нечистотии в канала. Ще открием и отстраним причината.' },
  { problem: 'Вода тече назад от канала', solution: 'Обратен ток на канализацията е сериозен проблем. Може да е нужна монтаж на възвратна клапа.' },
  { problem: 'Наводнен под от канализация', solution: 'Спешен случай, изискващ незабавна реакция. Идваме до 1 час.' },
];

const faq = [
  {
    q: 'Колко струва отпушване на канал в София?',
    a: 'Отпушването на канал в София струва между 70 и 120 лв. за стандартни случаи. При по-сложни запушвания цената може да е по-висока. Дадаваме точна цена след оглед — безплатно.',
  },
  {
    q: 'Колко бързо можете да дойдете при запушен канал?',
    a: 'При авария пристигаме в рамките на 1 час в София и прилежащите квартали. Обадете се веднага за да уточним кога можем да дойдем.',
  },
  {
    q: 'Могат ли домакинските средства (WC Дракон и др.) да отпушат канала?',
    a: 'Химическите средства могат да помогнат при леки запушвания, но при сериозни блокажи не работят и могат да наврдят тръбите. По-безопасно е да се обадите на специалист.',
  },
  {
    q: 'Как да предотвратя запушен канал?',
    a: 'Не изхвърляйте мазнини, мокри кърпички, памучни тампони и хигиенни продукти в тоалетната. Монтирайте цедка на мивките и душ-коритата.',
  },
  {
    q: 'Дава ли се гаранция за отпушването?',
    a: 'Даваме 12-месечна гаранция за извършената услуга. Ако проблемът се повтори в гаранционния период, идваме отново безплатно.',
  },
];
---

<ServiceLayout
  title="Отпушване на канал в София — бързо и ефективно | ВиК Петров"
  h1="Отпушване на канал в София — бързо и ефективно"
  description="Отпушване на запушен канал, тоалетна, мивка и душ в София. ВиК Петров — идваме до 1 час, 70–120 лв. Обадете се: 0896 934 144."
  slug="otpushvane-kanal"
  summary="ВиК Петров отпушва канали, тоалетни и мивки в София. Разполагаме с profesионално оборудване за механично и хидравлично почистване. В над 90% от случаите проблемът се решава при първото посещение."
  priceLabel="70–120 лв."
  priceItems={priceItems}
  whatIncluded={whatIncluded}
  whenNeeded={whenNeeded}
  faq={faq}
  relatedSlugs={['montaj-toaletna', 'montaj-mivka', 'avariyni-vik-uslugi']}
/>
