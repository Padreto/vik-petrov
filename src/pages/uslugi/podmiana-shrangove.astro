---
import ServiceLayout from '../../layouts/ServiceLayout.astro';

const priceItems = [
  { service: 'Подмяна на щрангове / стояци', price: 'Цена при оглед' },
  { service: 'Демонтаж и монтаж на водомер', price: '50–60 лв.' },
];

const whatIncluded = [
  'Безплатен оглед и точна оферта',
  'Координация с домоуправителя за спиране на водата',
  'Демонтаж на старите щрангове (хоризонтални и вертикални)',
  'Монтаж на нови тръби (PPR, PEX или медни)',
  'Свързване на отклонението за всеки апартамент',
  'Изпитване на налягане',
  'Документация при нужда',
];

const whenNeeded = [
  { problem: 'Чести течове от стояците', solution: 'Старите метални щрангове ръждясват и текат. Подмяната с PPR или медни тръби решава проблема за дълги години.' },
  { problem: 'Ниско налягане в цялата сграда', solution: 'Стеснените от ръжда тръби намаляват налягането. Нови тръби с правилни диаметри решават проблема.' },
  { problem: 'Ремонт на жилищна сграда', solution: 'При ремонт на мазе или стълбище е добра възможност да подмените и щранговете.' },
  { problem: 'Решение на ОС или управителен съвет', solution: 'Работим с управителни съвети и домоуправители. Организираме извършването с минимален дискомфорт за жителите.' },
];

const faq = [
  {
    q: 'Колко струва подмяна на щрангове в жилищна сграда?',
    a: 'Цената зависи от броя на апартаментите, вида тръби и достъпа. Безплатен оглед и детайлна оферта — обадете се.',
  },
  {
    q: 'Колко апартамента трябва да се договорят за подмяна на щрангове?',
    a: 'Подмяната на целия щранг е по-ефективна, но работим и с отделни секции. При частична подмяна цената е пропорционална.',
  },
  {
    q: 'Трябва ли да се спира водата за целия блок?',
    a: 'Да, за времето на подмяната трябва да се спре водата. Организираме работата така, че прекъсванията да са минимални — обикновено 3–6 часа на ден.',
  },
  {
    q: 'Какви тръби използвате?',
    a: 'Използваме PPR (полипропиленови) или медни тръби — в зависимост от предпочитанията и бюджета. И двата варианта са надеждни и дълготрайни.',
  },
];
---

<ServiceLayout
  title="Подмяна на щрангове в София — цени 2025 | ВиК Петров"
  h1="Подмяна на щрангове (стояци) в София — цени 2025"
  description="Подмяна на водопроводни щрангове и стояци в жилищни сгради в София. ВиК Петров — 8 години опит, безплатен оглед. Тел: 0896 934 144."
  slug="podmiana-shrangove"
  summary="ВиК Петров извършва подмяна на водопроводни щрангове в жилищни и административни сгради в София. Работим с домоуправители и управителни съвети. Цената се определя след безплатен оглед на място."
  priceLabel="Цена при оглед"
  priceItems={priceItems}
  whatIncluded={whatIncluded}
  whenNeeded={whenNeeded}
  faq={faq}
  relatedSlugs={['avariyni-vik-uslugi', 'smiana-vodomer']}
/>
