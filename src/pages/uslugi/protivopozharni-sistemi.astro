---
import ServiceLayout from '../../layouts/ServiceLayout.astro';

const priceItems = [
  { service: 'Монтаж на сухотръбна инсталация', price: 'Цена при оглед' },
  { service: 'Монтаж на спринклерна система с вода', price: 'Цена при оглед' },
  { service: 'Поддръжка и проверка на противопожарна система', price: 'Цена при оглед' },
];

const whatIncluded = [
  'Оглед и проектиране на инсталацията',
  'Монтаж на тръбопроводна мрежа (сухотръбие или с вода)',
  'Инсталиране на спринклерни глави или сухотръбни изходи',
  'Свързване към водопроводната система (при спринклери)',
  'Проверка на налягане и изпитване на системата',
  'Документация и протокол за изпълнение',
];

const whenNeeded = [
  { problem: 'Нова сграда или обект изискващ противопожарна инсталация', solution: 'Проектираме и монтираме система според нормите за обекта.' },
  { problem: 'Реновация с изискване за противопожарна защита', solution: 'Интегрираме нова система в съществуващата ВиК инфраструктура.' },
  { problem: 'Офис, търговски или складов обект', solution: 'Монтираме спринклерни или сухотръбни системи според предназначението.' },
  { problem: 'Жилищна сграда с много етажи', solution: 'Изграждаме сухотръбни вертикали с пожарни изходи на всеки етаж.' },
  { problem: 'Профилактика и поддръжка на съществуваща система', solution: 'Проверяваме налягане, спринклерни глави и изправност на целия контур.' },
];

const faq = [
  {
    q: 'Каква е разликата между сухотръбие и спринклерна система с вода?',
    a: 'Сухотръбието е тръбна мрежа без вода, предназначена за достъп на пожарната служба. Спринклерната система с вода е постоянно под налягане и се задейства автоматично при пожар.',
  },
  {
    q: 'За какви обекти е подходяща всяка система?',
    a: 'Сухотръбните инсталации се монтират предимно в жилищни сгради и стълбищни клетки. Спринклерните системи с вода са подходящи за офиси, хотели, търговски и складови обекти.',
  },
  {
    q: 'Трябва ли разрешително за монтаж на противопожарна система?',
    a: 'За по-мащабни обекти се изисква проект и съгласуване с противопожарните органи. При огледа ще ви информираме за необходимите документи.',
  },
  {
    q: 'Колко често трябва да се проверява системата?',
    a: 'Препоръчително е годишна профилактика — проверка на налягане, изправност на спринклерните глави и почистване на тръбите.',
  },
];
---

<ServiceLayout
  title="Противопожарни системи в София — спринклери и сухотръбие | ВиК Петров"
  h1="Монтаж на противопожарни системи в София — спринклери и сухотръбие"
  description="Монтаж и поддръжка на противопожарни ВиК системи в София — сухотръбни инсталации и спринклерни системи с вода. ВиК Петров, 12 години опит. Цена при оглед."
  slug="protivopozharni-sistemi"
  summary="ВиК Петров монтира противопожарни системи в София — сухотръбни инсталации и спринклерни системи с вода. Работим на жилищни сгради, офиси и търговски обекти. Цената се определя след безплатен оглед на място."
  priceLabel="Цена при оглед"
  priceItems={priceItems}
  whatIncluded={whatIncluded}
  whenNeeded={whenNeeded}
  faq={faq}
  relatedSlugs={['podmiana-shrangove', 'avariyni-vik-uslugi', 'montaj-bania']}
/>
