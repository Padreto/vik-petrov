---
import ServiceLayout from '../../layouts/ServiceLayout.astro';

const priceItems = [
  { service: 'Демонтаж и монтаж на водомер', price: '30–40 EUR' },
];

const whatIncluded = [
  'Затваряне на главния кран преди водомера',
  'Демонтаж на стария водомер',
  'Монтаж на новия водомер с уплътнения',
  'Проверка за течове и изпитване на налягане',
  'Пускане на водата и проверка на показанията',
  'Документация (при нужда)',
];

const whenNeeded = [
  { problem: 'Изтекъл мандат на водомера', solution: 'Водомерите имат мандат от 5 години. При изтичане трябва да ги смените — законово задължение.' },
  { problem: 'Неточни показания', solution: 'Ако сметките за вода са необяснимо високи или ниски, може да е повреден водомер. Ще проверим и ще препоръчаме смяна ако е нужно.' },
  { problem: 'Теч от водомера', solution: 'Теч при водомера или при фитингите около него е авария. Ще отстраним течовете и ще проверим дали водомерът трябва да се смени.' },
  { problem: 'Ремонт на апартамент', solution: 'При реновиране е добре да проверите и водомера. Ако е остарял, смяната сега ще ви спести проблеми по-нататък.' },
];

const faq = [
  {
    q: 'Колко струва смяна на водомер в София?',
    a: 'Смяната на водомер в София струва 50–60 лв. за труд. Водомерът обикновено се осигурява от клиента или от ВиК оператора. Обаждате се — ние монтираме.',
  },
  {
    q: 'Как да разбера дали водомерът ми трябва смяна?',
    a: 'Проверете датата на последната проверка (щампована на водомера). Мандатът е 5 години. Ако е изтекъл или ако показанията изглеждат нередовни, е нужна смяна.',
  },
  {
    q: 'Трябва ли да спирате цялата вода в блока?',
    a: 'Обикновено не. Спираме кранчето преди водомера (в стълбищното шахтово пространство). Само ако то не работи, трябва да се спира водата в шахтата.',
  },
  {
    q: 'Трябва ли ми разрешение от ВиК оператора?',
    a: 'За смяна на водомер след периодична проверка е нужно водомерът да мине проверка при ВиК оператора. Ще ви дадем насоки за процедурата.',
  },
];
---

<ServiceLayout
  title="Смяна на водомер в София — цена и процедура | ВиК Петров"
  h1="Смяна на водомер в София — цена и процедура"
  description="Смяна на водомер в София от ВиК Петров. Монтаж 50–60 лв. Работим всеки ден. Обадете се: 0896 934 144."
  slug="smiana-vodomer"
  summary="ВиК Петров извършва смяна и демонтаж на водомери в София. Процедурата отнема около 30 минути. Цената включва труд — без допълнителни такси за повикване."
  priceLabel="30–40 EUR"
  priceItems={priceItems}
  whatIncluded={whatIncluded}
  whenNeeded={whenNeeded}
  faq={faq}
  relatedSlugs={['avariyni-vik-uslugi', 'podmiana-shrangove']}
/>
