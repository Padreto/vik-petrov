---
import BaseLayout from '../layouts/BaseLayout.astro';
import { business } from '../data/business';
---

<BaseLayout
  title="Благодаря! Ще се свържем с вас — ВиК Петров"
  description="Заявката ви беше получена. ВиК Петров ще се свърже с вас до 30 минути."
  noindex={true}
>
  <section class="section bg-white min-h-[60vh] flex items-center">
    <div class="container text-center max-w-xl">
      <div class="w-20 h-20 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-6">
        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#10B981" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>
        </svg>
      </div>
      <h1 class="text-3xl font-bold text-text mb-4">Благодаря! Заявката е получена.</h1>
      <p class="text-xl text-text-secondary mb-8">
        Ще се свържем с вас до 30 минути. Ако е спешно — обадете се директно.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center mb-8">
        <a
          href={`tel:${business.phone.tel}`}
          class="btn-primary text-lg px-8 py-4"
          data-event="call_click"
          data-source="success_page"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1-9.4 0-17-7.6-17-17 0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z"/><path d="M15 5a4 4 0 014 4"/><path d="M15 2a7 7 0 017 7"/>
          </svg>
          {business.phone.display}
        </a>
        <a href="/" class="btn-secondary text-lg px-8 py-4">Към началото</a>
      </div>
    </div>
  </section>
</BaseLayout>
