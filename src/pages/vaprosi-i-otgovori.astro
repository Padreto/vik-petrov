---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import CTABlock from '../components/CTABlock.astro';
import { business } from '../data/business';

const faqs = [
  {
    category: 'Общи въпроси',
    items: [
      {
        q: 'Какви ВиК услуги предлагате?',
        a: 'ВиК Петров предлага пълен спектър от водопроводни и канализационни услуги: монтаж на санитария (вани, душ-кабини, мивки, тоалетни), монтаж на смесители, монтаж на бойлери, свързване на перални и съдомиялни, отпушване на канали, смяна на водомери и аварийни ВиК услуги.',
      },
      {
        q: 'В кои квартали на София работите?',
        a: 'Работим в цяла Sofia и прилежащите квартали: Панчарево, Кокаляне, Лозен, Герман, Горубляне, Бистрица, Бояна, Драгалевци, Симеоново, Младост, Дружба, Кривина, Казичене и Пасарел.',
      },
      {
        q: 'В кои дни и часове работите?',
        a: `Работим всеки ден, включително събота и неделя, от 07:00 до 22:00 ч. При спешни случаи се свържете с нас на ${business.phone.display}.`,
      },
    ],
  },
  {
    category: 'Цени и плащане',
    items: [
      {
        q: 'Колко ще струва ремонтът ми?',
        a: 'Цената зависи от вида услуга и конкретния обект. На страницата Цени ще намерите ориентировъчни цени. За точна оферта — безплатен оглед на място.',
      },
      {
        q: 'Имате ли такса за повикване?',
        a: 'Не. Нямаме такса за повикване. Плащате само за извършената работа.',
      },
      {
        q: 'Как плащате?',
        a: 'Плащате след завършването на работата. При по-голям проект може да се уговори авансово плащане.',
      },
      {
      },
    ],
  },
  {
    category: 'Качество и гаранция',
    items: [
      {
        q: 'Дава ли се гаранция за извършената работа?',
        a: `Да — даваме ${business.warranty} гаранция за всяка извършена услуга. Ако проблемът се появи отново в гаранционния период, идваме и го отстраняваме безплатно.`,
      },
      {
        q: 'Какво ако нещо се повреди след ремонта?',
        a: 'В рамките на гаранционния период от 12 месеца идваме и поправяме безплатно. Извън гаранцията ще оценим ситуацията и ще ви предложим решение.',
      },
      {
        q: 'Работите ли с качествени материали?',
        a: 'Да, използваме само сертифицирани материали от реномирани производители. Ако работим с материали, предоставени от клиента, не носим отговорност за тяхното качество.',
      },
    ],
  },
  {
    category: 'Аварийни случаи',
    items: [
      {
        q: 'Какво да направя при авария (теч, наводнение)?',
        a: 'Незабавно затворете главния кран за вода. Изключете ел. уредите в засегнатата зона. Обадете се на 0896 934 144. Докато чакате, опитайте да ограничите разпространението на водата.',
      },
      {
        q: 'Колко бързо реагирате при авария?',
        a: `В над 80% от случаите пристигаме в рамките на ${business.responseTime} в Sofia. При заетост ще ви кажем точното час на пристигане.`,
      },
    ],
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.flatMap(cat => cat.items.map(item => ({
    '@type': 'Question',
    name: item.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.a,
    },
  }))),
};
---

<BaseLayout
  title="Въпроси и отговори — ВиК Петров"
  description="Отговори на често задавани въпроси за ВиК услуги в София. Цени, гаранции, работно време и аварийни случаи — ВиК Петров."
  breadcrumbs={[{ name: 'Въпроси и отговори', url: '/vaprosi-i-otgovori/' }]}
  schema={faqSchema}
>
  <Breadcrumb items={[{ name: 'Въпроси и отговори' }]} />

  <section class="section bg-white">
    <div class="container max-w-3xl">
      <h1 class="text-4xl font-bold text-text mb-4">Въпроси и отговори</h1>
      <p class="text-xl text-text-secondary mb-12">
        Отговори на най-честите въпроси за нашите ВиК услуги в Sofia.
        Не намирате отговор? <a href={`tel:${business.phone.tel}`} class="text-primary font-semibold hover:underline">Обадете се директно.</a>
      </p>

      <div class="space-y-10">
        {faqs.map(cat => (
          <div>
            <h2 class="text-xl font-bold text-primary mb-4 pb-2 border-b border-primary/20">{cat.category}</h2>
            <div class="divide-y divide-gray-100">
              {cat.items.map((item, i) => (
                <div class="faq-item">
                  <button
                    class="faq-question"
                    aria-expanded="false"
                    aria-controls={`faq-${cat.category}-${i}`}
                  >
                    <span>{item.q}</span>
                    <span class="faq-icon text-primary text-xl font-bold shrink-0" aria-hidden="true">+</span>
                  </button>
                  <div id={`faq-${cat.category}-${i}`} class="faq-answer" style="display: none;">
                    {item.a}
                  </div>
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTABlock
    title="Все още имате въпроси?"
    subtitle="Обадете се директно — ще отговорим на всичко."
    source="faq_page_cta"
  />
</BaseLayout>
